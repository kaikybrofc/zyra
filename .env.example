# Where to store WhatsApp auth/session files
WA_AUTH_DIR=data/auth

# Print QR in terminal (true/false)
WA_PRINT_QR=true

# Logger level (trace|debug|info|warn|error|fatal)
LOG_LEVEL=info

# Redis URL for hot auth/store cache (optional)
WA_REDIS_URL=redis://localhost:6379

# Redis key prefix for connection cache
WA_REDIS_PREFIX=zyra:conexao
