# Onde salvar os arquivos de sessão do WhatsApp
WA_AUTH_DIR=data/auth

# Imprimir QR no terminal (true/false)
WA_PRINT_QR=true

# Nível de log (trace|debug|info|warn|error|fatal)
LOG_LEVEL=info

# URL do Redis para cache quente da sessão/store (opcional)
WA_REDIS_URL=redis://localhost:6379

# Prefixo das chaves do Redis
WA_REDIS_PREFIX=zyra:conexao

# URL de conexão MySQL para persistência (opcional)
MYSQL_URL=mysql://user:password@localhost:3306/zyra

# Alias legado para MYSQL_URL (opcional)
# WA_DB_URL=mysql://user:password@localhost:3306/zyra

# Identificador da conexão no banco
WA_CONNECTION_ID=default

# Aceitar mensagens da própria conta (true/false)
WA_ACCEPT_OWN_MESSAGES=false

# Timeouts do script de delete-session (em ms)
WA_DELETE_SESSION_TIMEOUT_MS=15000
WA_DELETE_SESSION_REDIS_MAX_MS=60000

# Ajustes de performance do backfill
WA_BACKFILL_LOG_SAMPLE=20
WA_BACKFILL_BATCH_SIZE=500
WA_BACKFILL_GROUP_LOG_EVERY=25
WA_BACKFILL_PARTICIPANT_LOG_EVERY=200
WA_BACKFILL_MESSAGE_LOG_EVERY=1000
