{
  "name": "zyra",
  "version": "0.1.5",
  "private": false,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
    "start:prod": "node dist/index.js",
    "db:init": "tsx src/core/db/init.ts",
    "db:verify": "tsx src/core/db/verify.ts",
    "db:delete-session": "tsx src/core/db/delete-session.ts",
    "db:backfill": "tsx src/core/db/backfill.ts",
    "db:nulls": "tsx src/core/db/null-report.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "patch-package",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@kaikybrofc/logger-module": "^1.0.4",
    "@whiskeysockets/baileys": "github:WhiskeySockets/Baileys",
    "dotenv": "^16.4.5",
    "mysql2": "^3.20.0",
    "qrcode-terminal": "^0.12.0",
    "redis": "^4.6.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.13.5",
    "@types/qrcode-terminal": "^0.12.2",
    "eslint": "^9.0.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "vite": "8.0.5"
  }
}
